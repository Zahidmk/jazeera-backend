# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/jazeera_db?schema=public"

# ─── Auth ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Odoo ERP ─────────────────────────────────────────────
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_odoo_database_name
ODOO_USERNAME=api_user@company.com
ODOO_API_KEY=your_odoo_api_key_here
ODOO_WEBHOOK_SECRET=CHANGE_THIS_TO_A_STRONG_32_CHAR_SECRET
ODOO_SCRAP_LOCATION_ID=14

# ─── File Uploads ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,https://dashboard.jazeera.com
